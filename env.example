# Copy to .env and fill in values
# cp env.example .env

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nexus-dev-password

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus-dev-password

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# API
API_PORT=3001
API_HOST=0.0.0.0

# Twitter/X API
X_BEARER_TOKEN=

# Client
CLIENT_PORT=5173

# Poll Interval Overrides (optional, ms, minimum 60000)
# POLL_INTERVAL_HACKERNEWS_MS=900000
# POLL_INTERVAL_ARXIV_MS=1800000
# POLL_INTERVAL_GITHUB_MS=3600000
# POLL_INTERVAL_TWITTER_MS=900000
