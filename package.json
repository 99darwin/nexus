{
  "name": "nexus",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev:api": "pnpm --filter @nexus/api dev",
    "dev:client": "pnpm --filter @nexus/client dev",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "seed": "tsx scripts/seed.ts",
    "backfill": "tsx scripts/backfill.ts",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "eslint": "^9.20.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0",
    "vitest": "^3.0.0"
  }
}
